<Window x:Class="Serio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Serio"
        mc:Ignorable="d"
        Width="800" Height="600" MinWidth="600" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="window_PreviewKeyDown"
        Background="#FF35393D"
        Topmost="True"
        xmlns:res="clr-namespace:Serio">

    <Grid Margin="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="23" />
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="6" Margin="-1,0,-1,0">
            <Menu x:Name="MainMenu" Background="#FF1E2023" IsMainMenu="True">
                <MenuItem Header="{x:Static res:Strings.MainMenuFile}" Foreground="#FFF2FFFF" MinHeight="23">
                    <MenuItem Foreground="Black" Header="{x:Static res:Strings.MainMenuFileExport}" Click="export_Click" ToolTip="{x:Static res:Strings.MainMenuFileExportToolTip}" Margin="2,0,0,1">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE78C;" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Foreground="Black" Header="{x:Static res:Strings.MainMenuFileQuit}" Click="exit_Click" Margin="2,0,0,1">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE7E8;" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="{x:Static res:Strings.MainMenuTools}" Foreground="#FFF2FFFF">
                    <!-- Copy Rx & Tx -->
                    <MenuItem Foreground="Black" Header="{x:Static res:Strings.MainMenuToolsCopyRx}" ToolTip="{x:Static res:Strings.MainMenuToolsCopyRxToolTip}" Click="copyRx_Click" Margin="2,0,0,1">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xF0E3;" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Foreground="Black" Header="{x:Static res:Strings.MainMenuToolsCopyTx}" ToolTip="{x:Static res:Strings.MainMenuToolsCopyTxToolTip}" Click="copyTx_Click" Margin="2,0,0,1">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xF0E3;" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <!-- Erase Rx & Tx -->
                    <MenuItem Foreground="Black" Header="{x:Static res:Strings.MainMenuToolsEraseRx}" ToolTip="{x:Static res:Strings.MainMenuToolsEraseRxToolTip}" StaysOpenOnClick="True" Click="eraseReceived_Click" Margin="2,0,0,1">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE75C;" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Foreground="Black" Header="{x:Static res:Strings.MainMenuToolsEraseTx}" ToolTip="{x:Static res:Strings.MainMenuToolsEraseTxToolTip}" StaysOpenOnClick="True" Click="eraseSent_Click" Margin="2,0,0,1">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE75C;" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <!-- Window on top -->
                    <MenuItem Foreground="Black" x:Name="MenuCheckboxOnTop" StaysOpenOnClick="True" Header="{x:Static res:Strings.MenuCheckboxOnTop}" IsChecked="True" IsCheckable="True" ToolTip="{x:Static res:Strings.MenuCheckboxOnTopToolTip}" Click="MenuCheckboxOnTop_Click" Margin="2,0,0,1" />
                    <Separator />
                    <!-- Wrapping -->
                    <MenuItem Foreground="Black" x:Name="MenuCheckboxWrapRx" StaysOpenOnClick="True" Header="{x:Static res:Strings.MenuCheckboxWrapRx}" IsCheckable="True" ToolTip="{x:Static res:Strings.MenuCheckboxWrapRxToolTip}" Margin="2,0,0,1" />
                    <MenuItem Foreground="Black" x:Name="MenuCheckboxWrapCRTx" StaysOpenOnClick="True" Header="{x:Static res:Strings.MenuCheckboxWrapCRTx}" IsCheckable="True" ToolTip="{x:Static res:Strings.MenuCheckboxWrapCRTxToolTip}" Margin="2,0,0,1" />
                    <MenuItem Foreground="Black" x:Name="MenuCheckboxWrapLFTx" StaysOpenOnClick="True" Header="{x:Static res:Strings.MenuCheckboxWrapLFTx}" IsCheckable="True" ToolTip="{x:Static res:Strings.MenuCheckboxWrapLFTxToolTip}" Margin="2,0,0,1" />
                </MenuItem>
                <!-- Port -->
                <MenuItem Header="{x:Static res:Strings.MainMenuPort}" Foreground="#FFF2FFFF">
                    <!-- DTR, RST -->
                    <MenuItem MinWidth="275" x:Name="MenuCheckboxDTR" Header="{x:Static res:Strings.MainMenuPortDtr}" ToolTip="{x:Static res:Strings.MainMenuPortDtrToolTip}" Foreground="Black" StaysOpenOnClick="True"  IsCheckable="True" Margin="2,0,0,1" Click="dtrCheckBox_Click" />
                    <MenuItem x:Name="MenuCheckboxRTS" Header="{x:Static res:Strings.MainMenuPortRst}" ToolTip="{x:Static res:Strings.MainMenuPortRstToolTip}" Foreground="Black" StaysOpenOnClick="True" IsCheckable="True" Margin="2,0,0,1" Click="rtsCheckBox_Click" />
                    <Separator />
                    <!-- Handshake -->
                    <MenuItem x:Name="MenuItemHandshake" StaysOpenOnClick="True" Margin="2,0,0,1">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Orientation="Vertical" Margin="0,5,0,5">
                                    <RepeatButton Content="&#xE971;" FontSize="14" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Click="buttonHandshakeUp_Click" />
                                    <RepeatButton Content="&#xE972;" FontSize="14" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Click="buttonHandshakeDown_Click" />
                                </StackPanel>
                                <Label x:Name="MenuLabelHandshake" Content="None" FontWeight="bold"  HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" />
                                <Label VerticalAlignment="Center"  Content="handshake" />
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <!-- Parity -->
                    <MenuItem x:Name="MenuItemParity" StaysOpenOnClick="True" Margin="2,0,0,1">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Orientation="Vertical" Margin="0,5,0,5">
                                    <RepeatButton Content="&#xE971;" FontSize="14" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Click="buttonParityUp_Click" />
                                    <RepeatButton Content="&#xE972;" FontSize="14" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Click="buttonParityDown_Click" />
                                </StackPanel>
                                <Label x:Name="MenuLabelParity" Content="None" FontWeight="bold"  HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" />
                                <Label VerticalAlignment="Center"  Content="{x:Static res:Strings.MainMenuPortParity}" />
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <!-- Data bits -->
                    <MenuItem x:Name="MenuItemDataBits" StaysOpenOnClick="True" Margin="2,0,0,1">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Orientation="Vertical" Margin="0,5,0,5">
                                    <RepeatButton Content="&#xE971;" FontSize="14" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Click="buttonDataBitsUp_Click" />
                                    <RepeatButton Content="&#xE972;" FontSize="14" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Click="buttonDataBitsDown_Click" />
                                </StackPanel>
                                <Label x:Name="MenuLabelDataBits" Content="8" FontWeight="bold"  HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" />
                                <Label VerticalAlignment="Center"  Content="{x:Static res:Strings.MainMenuPortDataBits}" />
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <!-- Stop bit -->
                    <MenuItem x:Name="MenuItemStopBit" StaysOpenOnClick="True" Margin="2,0,0,1">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Orientation="Vertical" Margin="0,5,0,5">
                                    <RepeatButton Content="&#xE971;" FontSize="14" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Click="buttonStopBitUp_Click" />
                                    <RepeatButton Content="&#xE972;" FontSize="14" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Click="buttonStopBitDown_Click" />
                                </StackPanel>
                                <Label x:Name="MenuLabelStopBit" Content="1" FontWeight="bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" />
                                <Label VerticalAlignment="Center" Content="{x:Static res:Strings.MainMenuPortStopBits}" />
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="{x:Static res:Strings.MainMenuHelp}" Foreground="#FFF2FFFF">
                    <MenuItem Foreground="Black" Header="{x:Static res:Strings.MainMenuHelpAbout}" Click="about_Click" Margin="2,0,0,1">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE82F;" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
            </Menu>
        </DockPanel>

        <TextBlock Foreground="#FFF2FFFF" Margin="7,0,0,0" HorizontalAlignment="Left" Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.LabelRx}" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBlock Foreground="#FFF2FFFF" HorizontalAlignment="Left" Margin="3,0,0,0" Grid.Row="1" Grid.Column="3" Text="{x:Static res:Strings.LabelTx}" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBox x:Name="textBox_Rx" Grid.ColumnSpan="3" Margin="7,0,3,10" TabIndex="5" IsTabStop="False" FontSize="16" FontFamily="Cascadia Mono, Consolas" VerticalScrollBarVisibility="Visible" Padding="5" Grid.Column="0" AcceptsReturn="True" IsReadOnly="True" Grid.RowSpan="2" Grid.Row="2"  IsEnabled="False" HorizontalScrollBarVisibility="Auto" Background="Black" Foreground="#FF92CAF4" TextWrapping="Wrap"/>
        <TextBox x:Name="textBox_Tx" Grid.ColumnSpan="3" Grid.Row="2" Margin="3,0,7,3" TabIndex="6" IsTabStop="False" FontSize="16" FontFamily="Cascadia Mono, Consolas" VerticalScrollBarVisibility="Visible" Padding="5" Grid.Column="3" AcceptsReturn="True" IsReadOnly="True" Grid.RowSpan="1" IsEnabled="False" HorizontalScrollBarVisibility="Auto" Background="Black" Foreground="#FF569CD6" TextWrapping="Wrap"/>
        <TextBox x:Name="textBox_Input" Grid.ColumnSpan="2" Margin="3,0,0,10" Padding="5" Grid.Column="3" Grid.RowSpan="1" Grid.Row="3" TabIndex="3" IsEnabled="False" Background="#FF17191C" Foreground="#FFF2FFFF" FontSize="16" TextWrapping="Wrap" ToolTip="{x:Static res:Strings.MainWindowInputToolTip}"/>
        <Button x:Name="button_Send" Foreground="#FF5E95BF" BorderBrush="Black" Background="#FF1E2023" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Content="&#xE725;" Grid.Row="3" Grid.Column="5" TabIndex="4" FontSize="16" Margin="5,0,7,10" Click="button_Send_Click" IsDefault="True" IsEnabled="False" ToolTip="{x:Static res:Strings.ButtonSendToolTip}"/>
        <ComboBox x:Name="comboBox_Port" Grid.Row="4" Margin="7,0,5,7" TabIndex="0" ToolTip="{x:Static res:Strings.ComboBoxPortToolTip}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontFamily="Cascadia Mono, Consolas" FontSize="14.667" FontWeight="Bold" SelectedIndex="0" Grid.ColumnSpan="2"/>
        <ComboBox x:Name="comboBox_BaudRate" Grid.Row="4" Grid.Column="2" Margin="0,0,5,7" TabIndex="1" ToolTip="{x:Static res:Strings.ComboBoxBaudRateToolTip}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="14.667" FontFamily="Cascadia Mono, Consolas" FontWeight="Bold" Grid.ColumnSpan="2" SelectionChanged="comboBox_BaudRate_SelectionChanged" />
        <Button x:Name="button_StartStop" Foreground="#FF5E95BF" BorderBrush="Black" Background="#FF1E2023" Content="{x:Static res:Strings.ButtonStartStopStart}" ToolTip="{x:Static res:Strings.ButtonStartStopToolTipStart}" Grid.Row="4" Grid.Column="4" Margin="0,0,0,7" TabIndex="2" FontSize="14.667" Click="button_StartStop_Click"/>
        <Rectangle x:Name="rectangle_Status" ToolTip="{x:Static res:Strings.StatusClosed}" Grid.Row="4" Grid.Column="5" Margin="5,0,7,7" Fill="#E81123"/>


    </Grid>
</Window>

